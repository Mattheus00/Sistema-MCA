# URL base do backend (Spring Boot SGI). Obrigatório para as requisições irem ao backend e não ao servidor do front.
# Ex.: http://localhost:8080 (backend na porta 8080). Sem barra no final.
VITE_API_URL=http://localhost:8080

# true = usa mock em memória (sem backend). false ou vazio = usa API real.
VITE_USE_MOCK=false
